# Copy this file to .env and fill in real values. Vite only exposes vars prefixed with VITE_.

# EmailJS (Contact form) — https://www.emailjs.com
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Supabase (Comments) — https://supabase.com
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Custom backend (see /Backend)
VITE_API_BASE_URL=https://portfolio-1-jypk.onrender.com/api
